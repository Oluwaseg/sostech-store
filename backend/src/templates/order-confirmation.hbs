<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Your Order is Confirmed</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background-color: #f5f5f5;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 24px auto;
        background: #ffffff;
        border-radius: 8px;
        padding: 24px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
      }
      .header {
        text-align: center;
        margin-bottom: 24px;
      }
      .logo {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
      }
      .subtitle {
        font-size: 13px;
        color: #6b7280;
      }
      .pill {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        background-color: #ecfdf3;
        color: #166534;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .section-title {
        font-size: 14px;
        font-weight: 600;
        margin: 16px 0 8px;
        color: #111827;
      }
      .muted {
        color: #6b7280;
        font-size: 13px;
      }
      .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin: 2px 0;
      }
      .summary-row strong {
        font-weight: 600;
      }
      .items {
        border-radius: 8px;
        background-color: #f9fafb;
        padding: 12px 14px;
        margin-top: 8px;
      }
      .item {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        padding: 4px 0;
        border-bottom: 1px solid #e5e7eb;
      }
      .item:last-child {
        border-bottom: none;
      }
      .footer {
        margin-top: 24px;
        font-size: 12px;
        color: #6b7280;
        text-align: center;
      }
      .code {
        font-family:
          Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
        background: #111827;
        color: #f9fafb;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 12px;
        letter-spacing: 0.08em;
        display: inline-block;
        margin-top: 4px;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <div class='logo'>SOSTECH Store</div>
        <div class='subtitle'>Order confirmation</div>
      </div>

      <p class='muted'>Hi {{name}},</p>
      <p class='muted'>
        Thank you for your purchase! Your payment was successful and your order
        has been confirmed.
      </p>

      <div>
        <div class='section-title'>Order details</div>
        <p class='muted'>
          Order ID:
          <span class='code'>{{orderId}}</span>
        </p>
        <div class='summary-row'>
          <span class='muted'>Payment status</span>
          <strong>{{paymentStatus}}</strong>
        </div>
        <div class='summary-row'>
          <span class='muted'>Shipping status</span>
          <strong>{{shippingStatus}}</strong>
        </div>
        <div class='summary-row' style='margin-top: 6px;'>
          <span class='muted'>Order total</span>
          <strong>₦{{total}}</strong>
        </div>
      </div>

      <div>
        <div class='section-title'>Items</div>
        <div class='items'>
          {{#each items}}
            <div class='item'>
              <span>{{name}} × {{quantity}}</span>
              <span>₦{{price}}</span>
            </div>
          {{/each}}
        </div>
      </div>

      <div>
        <div class='section-title'>Shipping to</div>
        <p class='muted'>
          {{shipping.addressLine}}<br />
          {{shipping.city}}{{#if shipping.state}}, {{shipping.state}}{{/if}}<br
          />
          {{shipping.country}}
          {{shipping.postalCode}}<br />
          Method:
          {{shipping.method}}
        </p>
      </div>

      <div class='footer'>
        <p>
          You will receive updates when your order ships and is delivered.<br />
          If you didn't make this purchase, please contact support immediately.
        </p>
        <p>© {{currentYear}} SOSTECH Store. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>