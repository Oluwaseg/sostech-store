<html>
  <body>
    <h1>Don't lose your items!</h1>
    <p>Hi {{name}},</p>
    <p>
      We noticed you left some items in your cart at VendorEase. They are still
      waiting for you.
    </p>
    <table
      cellpadding='0'
      cellspacing='0'
      style='width:100%; border-collapse: collapse;'
    >
      <thead>
        <tr>
          <th
            align='left'
            style='padding: 8px; border-bottom: 1px solid #ddd;'
          >Product</th>
          <th
            align='center'
            style='padding: 8px; border-bottom: 1px solid #ddd;'
          >Qty</th>
          <th
            align='right'
            style='padding: 8px; border-bottom: 1px solid #ddd;'
          >Price</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
          <tr>
            <td
              style='padding: 8px; border-bottom: 1px solid #f0f0f0;'
            >{{name}}</td>
            <td
              align='center'
              style='padding: 8px; border-bottom: 1px solid #f0f0f0;'
            >{{quantity}}</td>
            <td
              align='right'
              style='padding: 8px; border-bottom: 1px solid #f0f0f0;'
            >₦{{price}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    <p style='margin-top: 16px;'>
      <strong>Cart total:</strong>
      ₦{{total}}
    </p>
    <p>
      <a
        href='{{cartUrl}}'
        style='display: inline-block; padding: 12px 20px; background: #2563eb; color: white; text-decoration: none; border-radius: 5px;'
      >
        Return to your cart
      </a>
    </p>
    <p>If you need help, just reply to this email.</p>
    <p>Thanks,<br />The VendorEase team</p>
    <hr />
    <p style='font-size: 12px; color: #666;'>© {{currentYear}} VendorEase</p>
  </body>
</html>